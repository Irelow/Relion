# ─── Twilio ───────────────────────────────────────────────
# Trouvez ces valeurs sur https://console.twilio.com

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Numéro virtuel Twilio que vous achetez (~1€/mois)
# Format E.164 : +33757XXXXXX
TWILIO_PHONE_NUMBER=+33757000000

# ─── Vos numéros ──────────────────────────────────────────

# Votre numéro personnel pour recevoir les alertes nouveaux leads
OWNER_PHONE_NUMBER=+33600000000

# Numéro mobile de l'artisan (pour les notifications d'appels manqués)
ARTISAN_PHONE=+33600000000

ARTISAN_NAME=Martin Plomberie

# ─── SMS template ─────────────────────────────────────────
# Variables disponibles : {nom}, {url}
# Laissez vide pour utiliser le texte par défaut
SMS_TEMPLATE=

# Lien inclus dans le SMS automatique
RECALL_URL=https://relion.fr/rappel

# ─── Stripe ───────────────────────────────────────────────
# Trouvez ces valeurs sur https://dashboard.stripe.com/apikeys

# Clé secrète (sk_test_... en test, sk_live_... en production)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# IDs des prix créés dans Stripe Dashboard → Produits
# Créez "Relion Essentiel" et "Relion Pro" en abonnement mensuel
STRIPE_PRICE_ESSENTIEL=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PRO=price_xxxxxxxxxxxxxxxxxxxxxxxx

# Signing secret du webhook Stripe (whsec_...)
# Stripe Dashboard → Développeurs → Webhooks → votre endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# URL publique de votre site (sans slash final)
APP_URL=https://relion.vercel.app

# ─── Sécurité webhook Twilio ──────────────────────────────
VERCEL_URL=relion.vercel.app
WEBHOOK_URL=https://relion.vercel.app/api/missed-call
